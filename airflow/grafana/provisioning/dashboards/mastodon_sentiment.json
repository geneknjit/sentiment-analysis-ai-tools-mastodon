    {
      "id": 3,
      "type": "timeseries",
      "title": "Mean Compound Sentiment Score by Topic",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 24,
        "h": 10
      },
      "datasource": {
        "type": "postgres",
        "uid": "postgres-airflow"
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT\n  date_trunc('hour', created_at) AS time,\n  topic AS metric,\n  AVG(compound_score) AS value\nFROM sentiment_data\nWHERE $__timeFilter(created_at)\nGROUP BY 1, 2\nORDER BY 1;",
          "format": "time_series",
          "datasource": {
            "type": "postgres",
            "uid": "postgres-airflow"
          }
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true,
          "calcs": []
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": true,
            "axisPlacement": "auto",
            "axisLabel": "Compound score"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "barchart",
      "title": "Sentiment Distribution by Topic (%)",
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "postgres",
        "uid": "postgres-airflow"
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT topic, negative, neutral, positive\nFROM (\n  SELECT\n    topic,\n    ROUND(100.0 * SUM(CASE WHEN sentiment_category = 'negative' THEN 1 ELSE 0 END) / COUNT(*), 1) AS negative,\n    ROUND(100.0 * SUM(CASE WHEN sentiment_category = 'neutral'  THEN 1 ELSE 0 END) / COUNT(*), 1) AS neutral,\n    ROUND(100.0 * SUM(CASE WHEN sentiment_category = 'positive' THEN 1 ELSE 0 END) / COUNT(*), 1) AS positive\n  FROM sentiment_data\n  GROUP BY topic\n) sub\nORDER BY (neutral + positive) DESC;",
          "format": "table",
          "datasource": {
            "type": "postgres",
            "uid": "postgres-airflow"
          }
        }
      ],
      "options": {
        "orientation": "horizontal",
        "stacking": "normal",
        "showValue": "always",
        "barWidth": 0.7,
        "groupWidth": 0.7,
        "xTickLabelRotation": 0,
        "xTickLabelSpacing": 0,
        "legend": {
          "showLegend": true,
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        },
        "barRadius": 0.05,
        "fullHighlight": false,
        "xField": "topic"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 90,
            "axisPlacement": "auto",
            "axisLabel": "% of posts",
            "axisColorMode": "text",
            "axisBorderShow": false,
            "scaleDistribution": {
              "type": "linear"
            },
            "axisCenteredZero": false,
            "hideFrom": {
